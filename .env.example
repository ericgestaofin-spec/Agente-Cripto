# Modelo de configuração — copie para `.env` e preencha.
# O `.env` real é gitignored e NUNCA deve ser commitado (contém segredos).

# --- Anthropic (Claude) ---
# Necessária para o loop shadow analisar. Sem ela, o runner só monta o snapshot.
ANTHROPIC_API_KEY=cole_sua_chave_anthropic_aqui

# --- Bybit ---
# Market data é PÚBLICO (não precisa de chave). Estas só serão usadas quando
# houver um operador/execução (fase adiada). Use SEMPRE as chaves de DEMO
# até o gateway estar validado.
BYBIT_DEMO_KEY=cole_a_chave_demo_aqui
BYBIT_DEMO_SECRET=cole_o_secret_demo_aqui

# --- Persistência (opcional) ---
# Se definida, o loop grava as decisões em Postgres; senão, usa memória.
# Ex.: postgresql://agent:senha@localhost:5432/bybit_agent
# DATABASE_URL=

# Banco de teste do docker-compose (porta 5433), para o smoke de integração.
# TEST_DATABASE_URL=postgresql://agent:test@localhost:5433/bybit_agent_test

# Senha do Postgres de desenvolvimento (docker-compose).
# POSTGRES_PASSWORD=dev_only_never_in_prod

# --- Loop shadow (opcional) ---
SHADOW_TF=5              # timeframe de decisão (minutos)
SHADOW_DAILY_USD=5      # teto diário de custo com o Claude, em USD
